MARKET_DATA_PROVIDER=twelvedata
MARKET_DATA_MODE=live
TWELVE_DATA_API_KEY=
TWELVE_DATA_BASE_URL=https://api.twelvedata.com

# Macro Intelligence foundation. Live provider intentionally not configured in API-003A.
MACRO_DATA_PROVIDER=
MACRO_DATA_MODE=mock
MACRO_DATA_API_KEY=
MACRO_DATA_BASE_URL=

# News Intelligence foundation. Live provider intentionally not configured in API-004A.
NEWS_DATA_PROVIDER=
NEWS_DATA_MODE=mock
NEWS_DATA_API_KEY=
NEWS_DATA_API_SECRET=
NEWS_DATA_BASE_URL=

# JARVIS Core AI. Set AI_MODE=mock to use MockAIModelProvider without OpenAI cost.
AI_PROVIDER=openai
AI_MODE=live
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_STORE_RESPONSES=true
OPENAI_MAX_OUTPUT_TOKENS=1200
OPENAI_MAX_TOOL_CALLS=6
OPENAI_MAX_ITERATIONS=4
OPENAI_REQUEST_TIMEOUT_MS=20000
OPENAI_REASONING_EFFORT=low
OPENAI_STREAMING_ENABLED=false
OPENAI_MAX_TOOL_RESULT_BYTES=24000
OPENAI_REQUESTS_PER_MINUTE=12
OPENAI_MAX_CONVERSATION_REQUESTS=100

# Vision Intelligence foundation. API-006A intentionally uses Demo mode only.
VISION_PROVIDER=mock
VISION_MODE=mock
VISION_MAX_FILE_SIZE_BYTES=10485760
VISION_MAX_REQUEST_SIZE_BYTES=11534336
VISION_MAX_FILES_PER_REQUEST=1
VISION_ALLOWED_TYPES=image/png,image/jpeg,image/webp
VISION_MIN_WIDTH=480
VISION_MIN_HEIGHT=320
VISION_MAX_WIDTH=10000
VISION_MAX_HEIGHT=10000
VISION_MAX_PIXEL_COUNT=40000000
VISION_TEMP_RETENTION_HOURS=24
VISION_ANALYSIS_RETENTION_DAYS=30
VISION_RETAIN_ORIGINAL_IMAGE=false
VISION_UPLOADS_PER_MINUTE=10
VISION_ANALYSES_PER_MINUTE=20
VISION_MAX_ACTIVE_UPLOADS=2
VISION_MAX_ACTIVE_ANALYSES=2
VISION_TIMEOUT_MS=15000
VISION_SCHEMA_VERSION=1.0
VISION_ANALYSIS_VERSION=1.0
VISION_ENABLE_OCR=false
OPENAI_VISION_MODEL=
OPENAI_VISION_DETAIL=high
OPENAI_VISION_MAX_OUTPUT_TOKENS=2400
NODE_ENV=production
HOST=127.0.0.1
PORT=4174
APP_BASE_URL=http://127.0.0.1:4174
BUILD_VERSION=development

# Closed Beta access. When enabled, both an allowlisted email and invite code
# are required through server-side HTTP Basic authentication.
BETA_MODE=false
BETA_ALLOWED_EMAILS=
BETA_INVITE_CODES=
BETA_MAX_USERS=25

# Platform request controls. First Closed Beta limits are memory-local.
API_MAX_BODY_BYTES=1048576
API_REQUESTS_PER_MINUTE=120
BETA_JARVIS_REQUESTS_PER_MINUTE=12
BETA_VISION_UPLOADS_PER_MINUTE=6
BETA_VISION_ANALYSES_PER_MINUTE=10
BETA_SCANNER_REQUESTS_PER_MINUTE=6
BETA_MARKET_REQUESTS_PER_MINUTE=60
BETA_MACRO_REQUESTS_PER_MINUTE=30
BETA_NEWS_REQUESTS_PER_MINUTE=30
BETA_FEEDBACK_REQUESTS_PER_MINUTE=6
